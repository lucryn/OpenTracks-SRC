<phone:PhoneApplicationPage
    x:Class="OpenTracksBETA.marketplace"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:phone="clr-namespace:Microsoft.Phone.Controls;assembly=Microsoft.Phone"
    xmlns:shell="clr-namespace:Microsoft.Phone.Shell;assembly=Microsoft.Phone"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    FontFamily="{StaticResource PhoneFontFamilyLight}"
    FontSize="{StaticResource PhoneFontSizeNormal}"
    Foreground="{StaticResource PhoneForegroundBrush}"
    SupportedOrientations="Portrait" Orientation="Portrait"
    mc:Ignorable="d"
    shell:SystemTray.IsVisible="True">

    <!--Define slide animation resources-->
    <phone:PhoneApplicationPage.Resources>
        <Storyboard x:Name="SlideInStoryboard">
            <DoubleAnimation Storyboard.TargetName="ContentPanel"
                            Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.TranslateX)"
                            From="800" To="0"
                            Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Name="SlideOutStoryboard">
            <DoubleAnimation Storyboard.TargetName="ContentPanel"
                            Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.TranslateX)"
                            From="0" To="-800"
                            Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </phone:PhoneApplicationPage.Resources>

    <!--LayoutRoot is the root grid where all page content is placed-->
    <Grid x:Name="LayoutRoot" Background="{StaticResource PhoneBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!--TitlePanel contains the name of the application and page title-->
        <StackPanel Grid.Row="0" Margin="12,17,0,28">
            <TextBlock Text="OPEN TRACKS" 
                      Style="{StaticResource PhoneTextNormalStyle}" 
                      Foreground="#FF1DB954"
                      FontFamily="{StaticResource PhoneFontFamilyLight}"/>
            <TextBlock Text="Marketplace" 
                      Margin="9,-7,0,0" 
                      Style="{StaticResource PhoneTextTitle1Style}" 
                      FontSize="40"
                      FontWeight="ExtraLight"
                      FontFamily="{StaticResource PhoneFontFamilyLight}"/>
            <TextBlock Text="Music streaming services" 
                      Margin="9,-7,0,0" 
                      Style="{StaticResource PhoneTextSubtleStyle}" 
                      FontSize="16"
                      FontWeight="ExtraLight"
                      FontFamily="{StaticResource PhoneFontFamilyLight}"/>
        </StackPanel>

        <!--ContentPanel with slide transform-->
        <Grid x:Name="ContentPanel" Grid.Row="1" Margin="12,0,12,0">
            <Grid.RenderTransform>
                <CompositeTransform/>
            </Grid.RenderTransform>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Row 1, Column 1: Spotify -->
                    <Border Grid.Row="0" Grid.Column="0" 
                            Background="#FF1DB954" 
                            CornerRadius="0"
                            Height="160"
                            Tap="Spotify_Tap">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Ellipse Width="60" Height="60" Margin="0,0,0,12">
                                <Ellipse.Fill>
                                    <ImageBrush ImageSource="/Icon/spotify.png"/>
                                </Ellipse.Fill>
                            </Ellipse>
                            <TextBlock Text="SPOTIFY" 
                                      FontSize="20" 
                                      FontWeight="ExtraLight" 
                                      Foreground="White"
                                      FontFamily="{StaticResource PhoneFontFamilyLight}"/>
                        </StackPanel>
                    </Border>

                    <!-- Row 1, Column 2: YouTube Music -->
                    <Border Grid.Row="0" Grid.Column="2" 
                            Background="#FFFF0000" 
                            CornerRadius="0"
                            Height="160"
                            Tap="YTM_Tap">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Ellipse Width="60" Height="60" Margin="0,0,0,12">
                                <Ellipse.Fill>
                                    <ImageBrush ImageSource="/Icon/ytm.png"/>
                                </Ellipse.Fill>
                            </Ellipse>
                            <TextBlock Text="YOUTUBE MUSIC" 
                                      FontSize="20" 
                                      FontWeight="ExtraLight" 
                                      Foreground="White"
                                      FontFamily="{StaticResource PhoneFontFamilyLight}"/>
                        </StackPanel>
                    </Border>

                    <!-- Row 2, Column 1: Zendo -->
                    <Border Grid.Row="1" Grid.Column="0" 
                            Background="#FF646D74" 
                            CornerRadius="0"
                            Height="160"
                            Margin="0,12,0,0"
                            Tap="Zendo_Tap">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Ellipse Width="60" Height="60" Margin="0,0,0,12">
                                <Ellipse.Fill>
                                    <ImageBrush ImageSource="/Icon/zendro.png"/>
                                </Ellipse.Fill>
                            </Ellipse>
                            <TextBlock Text="ZENDO" 
                                      FontSize="20" 
                                      FontWeight="ExtraLight" 
                                      Foreground="White"
                                      FontFamily="{StaticResource PhoneFontFamilyLight}"/>
                        </StackPanel>
                    </Border>

                    <!-- Row 3, Column 2: Apple Music -->
                    <Border Grid.Row="1" Grid.Column="1" 
                            Background="#FF3E7FF1" 
                            CornerRadius="0"
                            Height="160"
                            Margin="11,12,1,0"
                            Tap="AppleMusic_Tap" Grid.ColumnSpan="2">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Ellipse Width="60" Height="60" Margin="0,0,0,12">
                                <Ellipse.Fill>
                                    <ImageBrush ImageSource="/Icon/OpenTracks.png"/>
                                </Ellipse.Fill>
                            </Ellipse>
                            <TextBlock Text="OpenPodcasts" 
                                      FontSize="20" 
                                      FontWeight="ExtraLight" 
                                      Foreground="White"
                                      FontFamily="{StaticResource PhoneFontFamilyLight}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</phone:PhoneApplicationPage>