<phone:PhoneApplicationPage
    x:Class="OpenTracksBETA.pagesex.r"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:shell="clr-namespace:Microsoft.Phone.Shell;assembly=Microsoft.Phone"
    xmlns:phone="clr-namespace:Microsoft.Phone.Controls;assembly=Microsoft.Phone"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Orientation="Portrait">


    <!--LayoutRoot is the root grid where all page content is placed-->
    <Grid x:Name="LayoutRoot10" Background="Transparent">

        <!-- LOCALIZATION NOTE:
            To localize the displayed strings copy their values to appropriately named
            keys in the app's neutral language resource file (AppResources.resx) then
            replace the hard-coded text value between the attributes' quotation marks
            with the binding clause whose path points to that string name.

            For example:

                Text="{Binding Path=LocalizedResources.ApplicationTitle, Source={StaticResource LocalizedStrings}}"

            This binding points to the template's string resource named "ApplicationTitle".

            Adding supported languages in the Project Properties tab will create a
            new resx file per language that can carry the translated values of your
            UI strings. The binding in these examples will cause the value of the
            attributes to be drawn from the .resx file that matches the
            CurrentUICulture of the app at run time.
         -->

        <!--Panorama control-->
        <Grid.Resources>
            <Style x:Key="CircularButtonStyle" TargetType="Button">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="40"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Storyboard x:Name="MarqueeStoryboard" RepeatBehavior="Forever">
                <DoubleAnimation Storyboard.TargetName="TrackTransform"
                       Storyboard.TargetProperty="TranslateX"
                       From="300" To="-600"
                       Duration="0:0:10" />
            </Storyboard>
        </Grid.Resources>
        <phone:Panorama Title="Remixin Place">
            <phone:Panorama.Background>
                <ImageBrush ImageSource="/Assets/explore/f.jpg" Opacity="0.6" Stretch="UniformToFill"/>
            </phone:Panorama.Background>

            <!--welcome-->
            <phone:PanoramaItem Header="Best Remixes:">
                <ListBox x:Name="RTracks" ItemsSource="{Binding RTracks}" SelectionChanged="RTracks_SelectionChanged"
              Margin="-16,-10,0,139">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="10">
                                <!-- Icon or spacing element (optional) -->
                                <Rectangle Width="10" Fill="Transparent" />

                                <!-- Text with larger font and custom alignment -->
                                <TextBlock Text="{Binding Title}"
                           FontSize="28"
                           FontWeight="Bold"
                           FontFamily="Segoe WP Light"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </phone:PanoramaItem>
            <phone:PanoramaItem>
                <TextBlock HorizontalAlignment="Left" Margin="16,-22,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="487" Width="400" FontSize="24">
        	    <Run Text="Love remix more than original tracks? or loved how people using their creative mind to recreate a music? then remixin place is best for you...   lets get fire!➜"/>
                </TextBlock>
            </phone:PanoramaItem>
        </phone:Panorama>
        <StackPanel VerticalAlignment="Bottom"
            HorizontalAlignment="Stretch"
            Background="#FF272727"
            Height="140">

            <!-- 🔊 Top Row: Track Title & Play Button -->
            <StackPanel Orientation="Horizontal"
              Height="80"
              Margin="0">
                <TextBlock x:Name="CurrentTrackName"
               FontSize="40"
               FontWeight="Light"
               Foreground="White"
               Text=" Nothing is playing .."
               TextWrapping="NoWrap"
               RenderTransformOrigin="0.5,0.5"
               VerticalAlignment="Center"
               HorizontalAlignment="Left"
               Margin="10,16,0,4"
               Width="372"
               Height="60">
                    <TextBlock.RenderTransform>
                        <CompositeTransform x:Name="TrackTransform" />
                    </TextBlock.RenderTransform>
                </TextBlock>

                <Button x:Name="PlayPauseButton"
            Width="66"
            Height="70"
            Content="▶"
            FontSize="32"
            FontWeight="Bold"
            Background="{x:Null}"
            Foreground="White"
            BorderBrush="White"
            BorderThickness="2"
            Style="{StaticResource CircularButtonStyle}"
            Click="PlayPauseButton_Click"
            VerticalAlignment="Center"
            HorizontalAlignment="Right"
            Margin="10,10,10,0" />
            </StackPanel>

            <!-- 📊 Slider Row: Time Labels + Seek Bar -->
            <StackPanel Orientation="Horizontal"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Center"
              Height="40"
              Margin="10,0,10,10">

                <TextBlock x:Name="StartTimeLabel"
               Text="0:00"
               FontSize="18"
               Foreground="White"
               VerticalAlignment="Center"
               Margin="0,10,10,0" Height="30" />

                <Slider x:Name="ProgressSlider"
            Minimum="0"
            Maximum="100"
            Value="0"
            Width="346"
            Height="118"
            Background="#FF5F5F5F"
            Foreground="White"
            BorderBrush="{x:Null}"
            ValueChanged="ProgressSlider_ValueChanged"
            VerticalAlignment="Center" Margin="0,-23,0,-55" />

                <TextBlock x:Name="EndTimeLabel"
               Text="0:00"
               FontSize="18"
               Foreground="White"
               VerticalAlignment="Center"
               Margin="10,0,0,0" />
            </StackPanel>
        </StackPanel>
        <MediaElement x:Name="AudioPlayer" AutoPlay="False" />
    </Grid>
    <phone:PhoneApplicationPage.ApplicationBar>
        <shell:ApplicationBar IsVisible="True" IsMenuEnabled="True" Mode="Minimized">
            <shell:ApplicationBar.MenuItems>
                <shell:ApplicationBarMenuItem Text="back to home" Click="Home_Click"/>
            </shell:ApplicationBar.MenuItems>
        </shell:ApplicationBar>
    </phone:PhoneApplicationPage.ApplicationBar>
</phone:PhoneApplicationPage>