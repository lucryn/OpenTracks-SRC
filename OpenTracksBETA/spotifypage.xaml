<phone:PhoneApplicationPage
    x:Class="OpenTracksBETA.SpotifyPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:phone="clr-namespace:Microsoft.Phone.Controls;assembly=Microsoft.Phone"
    xmlns:shell="clr-namespace:Microsoft.Phone.Shell;assembly=Microsoft.Phone"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    FontFamily="{StaticResource PhoneFontFamilyNormal}"
    FontSize="{StaticResource PhoneFontSizeNormal}"
    Foreground="{StaticResource PhoneForegroundBrush}"
    SupportedOrientations="Portrait" Orientation="Portrait"
    shell:SystemTray.IsVisible="True">

    <phone:PhoneApplicationPage.Resources>
        <!-- Liquid Glass Panel Style -->
        <Style x:Key="LiquidGlassPanel" TargetType="Border">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#4DFFFFFF" Offset="0"/>
                        <GradientStop Color="#28FFFFFF" Offset="0.3"/>
                        <GradientStop Color="#14FFFFFF" Offset="0.7"/>
                        <GradientStop Color="#0AFFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#40FFFFFF"/>
        </Style>

        <!-- Floating Button Style -->
        <Style x:Key="FloatingButton" TargetType="Button">
            <Setter Property="Background" Value="#FF46A7F7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="18">
                                <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- iOS 26 TextBox Style -->
        <Style x:Key="iOS26TextBox" TargetType="TextBox">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#30FFFFFF" Offset="0"/>
                        <GradientStop Color="#15FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                            BorderBrush="#40FFFFFF"
                            BorderThickness="1"
                            CornerRadius="16">
                                <ScrollViewer x:Name="ContentElement"
                                      Padding="{TemplateBinding Padding}"
                                      Background="Transparent"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- iOS 26 ListBox Style -->
        <Style x:Key="iOS26ListBox" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- Panorama Header Style -->
        <Style x:Key="iOS26PanoramaHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="32"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="20,15,20,10"/>
        </Style>

        <!-- Progress Bar Style -->
        <Style x:Key="iOS26ProgressBar" TargetType="ProgressBar">
            <Setter Property="Foreground" Value="#1DB954"/>
            <Setter Property="Background" Value="#333"/>
            <Setter Property="Height" Value="6"/>
        </Style>

        <!-- PanoramaItemHeader Style -->
        <Style x:Key="PanoramaItemHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="20,10,20,5"/>
        </Style>
    </phone:PhoneApplicationPage.Resources>


    <Grid x:Name="LayoutRoot">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.Background>
            <ImageBrush Stretch="Fill" ImageSource="/Assets/bg1.png" Opacity="0.6"/>
        </Grid.Background>

        <!-- iOS 26 Liquid Glass Header -->
        <Border Grid.Row="0"
        BorderBrush="#333"
        BorderThickness="0,0,0,1">
            <StackPanel Margin="20,12,20,15" Background="Transparent">
                <TextBlock Text="SpotStore (Preview)"
                   Foreground="White"
                   FontSize="18"
                   FontWeight="ExtraLight"/>
                <TextBlock x:Name="NowPlayingText"
                   Text="Login for more!"
                   Foreground="White"
                   FontSize="26"
                   FontWeight="ExtraLight"
                   Margin="0,5,0,0"/>
            </StackPanel>
        </Border>


        <!-- CREDENTIALS ENTRY PANEL -->
        <StackPanel x:Name="CredentialsPanel" Grid.Row="1" Visibility="Collapsed" VerticalAlignment="Center">
            <TextBlock Text="Enter your Spotify Developer App credentials to continue:" HorizontalAlignment="Center" Margin="30,10" TextWrapping="Wrap" TextAlignment="Center"/>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Client ID:" FontSize="16" Margin="0,10,0,5" Foreground="White"/>
                    <TextBox x:Name="ClientIdTextBox" Height="70" FontSize="18" Background="#333" Foreground="White" VerticalContentAlignment="Center"/>

                    <TextBlock Text="Client Secret:" FontSize="16" Margin="0,10,0,5" Foreground="White"/>
                    <TextBox x:Name="ClientSecretTextBox" Height="70" FontSize="18" Background="#333" Foreground="White" VerticalContentAlignment="Center"/>

                    <TextBlock Text="Redirect URI:" FontSize="16" Margin="0,10,0,5" Foreground="White"/>
                    <TextBox x:Name="RedirectUriTextBox" Height="70" FontSize="18" Background="#333" Foreground="White" VerticalContentAlignment="Center"/>

                    <TextBlock Text="YouTube API Key (Required):" FontSize="16" Margin="0,10,0,5" Foreground="White"/>
                    <TextBox x:Name="YouTubeApiKeyTextBox" Height="70" FontSize="18" Background="#333" Foreground="White" VerticalContentAlignment="Center"/>
                    <TextBlock Text="Get free API key from: https://console.cloud.google.com" FontSize="12" Margin="0,5,0,10" Foreground="LightGray" TextWrapping="Wrap"/>

                    <Button x:Name="SaveCredentialsButton" Content="Save Credentials" 
                            Click="SaveCredentialsButton_Click" Height="70" Margin="0,20,0,10" 
                            Background="#1DB954" Foreground="White" FontSize="18"/>

                    <Button x:Name="HowToGetCredentialsButton" Content="How to Get Credentials" 
                            Click="HowToGetCredentials_Click" Height="60" 
                            Background="#1877B5" Foreground="White" FontSize="16"/>



                </StackPanel>
            </ScrollViewer>
        </StackPanel>

        <!-- LOGIN PANEL -->
        <StackPanel  Visibility="Collapsed" x:Name="LoginPanel" Grid.Row="1" VerticalAlignment="Center">
            <TextBlock Text="OpenSpot (BETA)" FontSize="28" HorizontalAlignment="Center" Margin="20" Foreground="#1DB954"/>
            <TextBlock Text="Login with authorization code" HorizontalAlignment="Center" Margin="20" TextWrapping="Wrap" TextAlignment="Center"/>

            <Button Content="Enter Authorization Code" Click="StartCodeEntry_Click" 
                    Background="#1DB954" Foreground="White" FontSize="20" Padding="20,10" Margin="20"/>

            <Button Content="Edit Credentials" Click="EditCredentialsButton_Click" 
                    Background="#666" Foreground="White" FontSize="16" Padding="15,8" Margin="20,10"/>
            <Button x:Name="HowToGetYouTubeApiKeyButton" Content="How to Get YouTube API Key" 
        Click="HowToGetYouTubeApiKey_Click" Height="70" 
        Background="#FF6D00" Foreground="White" FontSize="16" Margin="0,10,0,5"/>
        </StackPanel>

        <!-- CODE ENTRY PANEL -->
        <StackPanel x:Name="CodeEntryPanel" Grid.Row="1" Visibility="Collapsed" VerticalAlignment="Center" >
            <TextBlock Text="Enter Authorization Code" FontSize="24" HorizontalAlignment="Center" Margin="20" Foreground="#1DB954"/>
            <TextBlock Text="Paste the code from Spotify (starts with AQC...):" HorizontalAlignment="Center" Margin="10" TextWrapping="Wrap" TextAlignment="Center"/>

            <TextBox x:Name="CodeTextBox" Height="80" Margin="20" FontSize="18" 
                    VerticalContentAlignment="Center" Background="#333" Foreground="White"/>

            <Button Content="Login" Click="SubmitCode_Click" 
                    Background="#1DB954" Foreground="White" FontSize="20" Padding="20,10" Margin="20"/>

            <Button Content="Back" Click="BackToLogin_Click" 
                    Background="#666" Foreground="White" Margin="10"/>

            <Button Content="Back to Credentials" Click="BackToCredentials_Click" 
                    Background="#444" Foreground="White" Margin="10,5"/>
        </StackPanel>

        <!-- MAIN APP PANEL -->
        <StackPanel x:Name="MainAppPanel" Grid.Row="1" Visibility="Visible" VerticalAlignment="Center">
            <phone:Panorama Grid.Row="1" Foreground="White"
                          Background="Transparent">

                <!-- Now Playing Section -->
                <phone:PanoramaItem Header="Now Playing" Margin="0,0,0,10">
                    <phone:PanoramaItem.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Style="{StaticResource iOS26PanoramaHeader}"/>
                        </DataTemplate>
                    </phone:PanoramaItem.HeaderTemplate>

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Margin="0,0,0,128"
                  Padding="0" Height="561" VerticalAlignment="Center">
                        <StackPanel Margin="10">
                            <!-- Enhanced Album Art Container -->
                            <Border Style="{StaticResource LiquidGlassPanel}"
                    Height="291" Width="348"
                    HorizontalAlignment="Center"
                    Margin="0,10,0,20">
                                <Grid>
                                    <Image x:Name="AlbumImage" Stretch="Uniform"
                           Margin="10" VerticalAlignment="Center"
                           Opacity="0.9"/>
                                    <Button x:Name="OverlayPlayButton" Content="▶"
                            Click="OverlayPlayButton_Click"
                            Background="#801DB954"
                            Foreground="White" FontSize="40"
                            Width="80" Height="80"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Visibility="Collapsed"
                            BorderThickness="0">
                                    </Button>
                                    <ProgressBar x:Name="OverlayLoadingSpinner"
                                 IsIndeterminate="True"
                                 Visibility="Collapsed"
                                 Width="60" Height="60"
                                 VerticalAlignment="Center"
                                 HorizontalAlignment="Center"
                                 Foreground="#1DB954"
                                 Style="{StaticResource iOS26ProgressBar}"/>
                                </Grid>
                            </Border>

                            <!-- Enhanced Track Info -->
                            <Border Style="{StaticResource LiquidGlassPanel}" Margin="20,0,20,15"
                    Background="#201DB954" Height="76">
                                <StackPanel Margin="15,10">
                                    <TextBlock x:Name="NowPlayingTitle" Text="→ swipe left to get started"
                               FontSize="22" Foreground="White"
                               FontWeight="ExtraLight" TextWrapping="Wrap"
                               TextAlignment="Center"/>
                                    <TextBlock x:Name="NowPlayingArtist" Text="nothing is playing right now.."
                               FontSize="14" Foreground="#FF399DE2"
                               TextAlignment="Center" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Enhanced YouTube Status -->
                            <Border Style="{StaticResource LiquidGlassPanel}"
                    Margin="20,0,20,15"
                    Background="#20FF0000"
                    x:Name="YouTubeStatusBorder">
                            </Border>

                            <!-- Enhanced Progress Controls -->
                            <Border Style="{StaticResource LiquidGlassPanel}" Padding="15" Width="374">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="CurrentTimeText" Text="0:00"
                                   FontSize="12" Foreground="LightGray"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <ProgressBar x:Name="ProgressBar" Minimum="0" Maximum="100" Value="0"
                                     Height="8" Foreground="#1DB954" Background="#333"
                                     Grid.Column="1" VerticalAlignment="Center"
                                     Style="{StaticResource iOS26ProgressBar}"/>
                                        <TextBlock x:Name="TotalTimeText" Text="0:00"
                                   FontSize="12" Foreground="LightGray"
                                   VerticalAlignment="Center" Margin="10,0,0,0"
                                   Grid.Column="2"/>
                                    </Grid>

                                    <!-- Enhanced Playback Controls -->
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
                                        <Button x:Name="ShuffleButton" Content="🔀"
                                Click="ShuffleButton_Click"
                                Style="{StaticResource FloatingButton}"
                                Width="80" FontSize="14"
                                Background="Transparent" BorderBrush="#40FFFFFF"
                                Margin="0,5,10,0"/>
                                        <Button x:Name="PlayPauseButton" Content="▶"
                                Click="PlayPauseButton_Click"
                                Style="{StaticResource FloatingButton}" Width="108"
                                Background="#1DB954" FontSize="26" Margin="0,3,15,0" Height="59"/>
                                        <Button x:Name="RepeatButton" Content="🔁"
                                Click="RepeatButton_Click"
                                Style="{StaticResource FloatingButton}"
                                Width="70" FontSize="14"
                                Background="Transparent" BorderBrush="#40FFFFFF" Margin="0,5,0,0"/>
                                    </StackPanel>

                                    <!-- Enhanced YouTube Controls -->
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15">
                                        <Button Content="🔊" Click="VolumeButton_Click"
                                Style="{StaticResource FloatingButton}"
                                Width="90" Height="62" FontSize="14"
                                Background="Transparent" BorderBrush="#40FFFFFF"
                                Margin="0,0,10,0"/>
                                        <Button x:Name="PlaybackSpeedButton" Content="1.0×"
                                Click="PlaybackSpeedButton_Click"
                                Style="{StaticResource FloatingButton}"
                                Width="100" Height="67" FontSize="12"
                                Background="#20FF0000" Foreground="#FF6D00"
                                Margin="0,0,10,0"/>
                                        <Button Content="📥" Click="DownloadButton_Click"
                                Style="{StaticResource FloatingButton}"
                                Width="97" Height="64" FontSize="14"
                                Background="Transparent" BorderBrush="#40FFFFFF"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Enhanced Quick Actions -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
                                <Button Content="Add to Playlist" Click="AddToPlaylistButton_Click"
                        Style="{StaticResource FloatingButton}" Width="120"
                        Background="#2066BBFF" Foreground="#66BBFF" FontSize="12"
                        Margin="5"/>
                                <Button Content="Share Track" Click="ShareTrackButton_Click"
                        Style="{StaticResource FloatingButton}" Width="119"
                        Background="#2066FF66" Foreground="#66FF66" FontSize="12"
                        Margin="5"/>
                                <Button Content="View Lyrics" Click="ViewLyricsButton_Click"
                        Style="{StaticResource FloatingButton}" Width="100"
                        Background="#20FF6666" Foreground="#FF6666" FontSize="12"
                        Margin="5"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </phone:PanoramaItem>

                <!-- Search Section -->
                <!-- Search Section -->
                <phone:PanoramaItem Header="Search">
                    <phone:PanoramaItem.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Style="{StaticResource iOS26PanoramaHeader}"/>
                        </DataTemplate>
                    </phone:PanoramaItem.HeaderTemplate>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="10">
                            <!-- Search Box -->
                            <Border Style="{StaticResource LiquidGlassPanel}" Margin="20,10,20,20">
                                <StackPanel>
                                    <TextBox x:Name="SearchTextBox" Text="Search for tracks..."
                             GotFocus="SearchTextBox_GotFocus" LostFocus="SearchTextBox_LostFocus"
                             KeyDown="SearchTextBox_KeyDown" FontSize="18" Height="60"
                             Background="Transparent" Foreground="White" BorderThickness="0"
                             Padding="15,0" Style="{StaticResource iOS26TextBox}"/>
                                    <Button x:Name="SearchButton" Content="Search" Click="SearchButton_Click"
                            Style="{StaticResource FloatingButton}" Margin="10,0,10,10" Height="69"/>
                                </StackPanel>
                            </Border>

                            <!-- Loading Indicator -->
                            <Border Style="{StaticResource LiquidGlassPanel}" Margin="20,10" Visibility="Collapsed">
                                <ProgressBar x:Name="LoadingProgressBar" Visibility="Collapsed"
                             IsIndeterminate="True" Height="4" Foreground="#1DB954"
                             Margin="20" Style="{StaticResource iOS26ProgressBar}"/>
                            </Border>

                            <!-- Search Results -->
                            <Border Style="{StaticResource LiquidGlassPanel}" Margin="20,10">
                                <StackPanel>
                                    <TextBlock Text="Search Results" FontSize="18" Margin="15,10"
                               Foreground="LightGray" FontWeight="SemiBold"/>
                                    <ListBox x:Name="ResultsListBox" Height="200" Background="Transparent"
                             SelectionChanged="ResultsListBox_SelectionChanged"
                             BorderThickness="0" Padding="5" Style="{StaticResource iOS26ListBox}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#20FFFFFF" Margin="5">
                                                    <StackPanel Margin="10">
                                                        <TextBlock Text="{Binding Name}" FontSize="16"
                                                   Foreground="White" FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding Artists[0].Name}" FontSize="14"
                                                   Foreground="#1DB954"/>
                                                        <TextBlock Text="{Binding Album.Name}" FontSize="12"
                                                   Foreground="LightGray"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <TextBox x:Name="YouTubeStatusText" Text="No Tracks Selected."
                             KeyDown="SearchTextBox_KeyDown" FontSize="18" Height="60"
                             Foreground="White" BorderThickness="0" Padding="15,0"
                             Background="#BF0074FF" Style="{StaticResource iOS26TextBox}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </phone:PanoramaItem>

                <!-- Premium Hub Section -->
                <phone:PanoramaItem Header="Premium Hub">
                    <phone:PanoramaItem.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Style="{StaticResource iOS26PanoramaHeader}"/>
                        </DataTemplate>
                    </phone:PanoramaItem.HeaderTemplate>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="10">
                            <Border Style="{StaticResource LiquidGlassPanel}" Margin="20,10" Background="#201DB954">
                                <TextBlock x:Name="HELP" TextAlignment="Center"
                           Text="Only Spotify Premium Users with device playing music can use this."
                           Style="{StaticResource PhoneTextTitle2Style}"
                           Margin="15,10" TextWrapping="Wrap" Foreground="White"/>
                            </Border>

                            <!-- Floating Control Buttons -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20">
                                <Button Content="⏮" Click="PrevButton_Click"
                        Style="{StaticResource FloatingButton}" Width="107"
                        Background="#444" FontSize="20" Height="74"/>
                                <Button x:Name="PlayButton" Content="▶" Click="PlayButton_Click"
                        Style="{StaticResource FloatingButton}" Width="137"
                        Background="#1DB954" FontSize="20" Margin="15,0" Height="66"/>
                                <Button Content="⏭" Click="NextButton_Click"
                        Style="{StaticResource FloatingButton}" Width="107"
                        Background="#444" FontSize="20" Height="71"/>
                            </StackPanel>

                            <!-- YouTube Play Button -->
                            <Button x:Name="PlayYouTubeButton" Content="🎵 Play on Phone"
                    Click="PlayYouTubeButton_Click"
                    Style="{StaticResource FloatingButton}"
                    Background="#FF0000" FontSize="16"
                    Margin="40,20,40,10" Width="280" Height="67"/>
                        </StackPanel>
                    </ScrollViewer>
                </phone:PanoramaItem>

                <!-- Settings Section -->
                <phone:PanoramaItem Header="Settings">
                    <phone:PanoramaItem.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Style="{StaticResource iOS26PanoramaHeader}"/>
                        </DataTemplate>
                    </phone:PanoramaItem.HeaderTemplate>

                    <ScrollViewer>
                        <StackPanel Margin="10">
                            <!-- Enhanced Action Buttons -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20">
                                <Button Content="Logout" Click="LogoutButton_Click" 
                                    Style="{StaticResource FloatingButton}" Width="130" 
                                    Background="#E22134" Margin="5" Height="73"/>
                                <Button Content="Edit Credentials" Click="EditCredentialsButton_Click" 
                                    Style="{StaticResource FloatingButton}" Width="263" 
                                    Background="#666" Margin="5" Height="71"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </phone:PanoramaItem>
            </phone:Panorama>
        </StackPanel>
        <!-- Add this hidden MediaElement for audio playback -->
        <!-- Replace your hidden MediaElement with this visible one -->
        <MediaElement x:Name="AudioPlayer" 
              Volume="1.0" 
              AutoPlay="True"
              Visibility="Visible"
              Height="0"
            MediaOpened="AudioPlayer_MediaOpened"
              MediaFailed="AudioPlayer_MediaFailed"
              MediaEnded="AudioPlayer_MediaEnded"/>
    </Grid>
</phone:PhoneApplicationPage>