<phone:PhoneApplicationPage
    x:Class="OpenTracksBETA.Personal_DJ"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:phone="clr-namespace:Microsoft.Phone.Controls;assembly=Microsoft.Phone"
    xmlns:shell="clr-namespace:Microsoft.Phone.Shell;assembly=Microsoft.Phone"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:toolkit="clr-namespace:Microsoft.Phone.Controls;assembly=Microsoft.Phone.Controls.Toolkit"
    FontFamily="{StaticResource PhoneFontFamilyNormal}"
    FontSize="{StaticResource PhoneFontSizeNormal}"
    Foreground="{StaticResource PhoneForegroundBrush}"
    SupportedOrientations="Portrait"
    Orientation="Portrait"
    mc:Ignorable="d"
    shell:SystemTray.IsVisible="True">

    <Grid x:Name="LayoutRoot"
          Loaded="LayoutRoot_Loaded"
          RenderTransformOrigin="0.5,0.5"
          >
        <Grid.RenderTransform>
            <TranslateTransform x:Name="LayoutRootTransform" Y="100"/>
        </Grid.RenderTransform>

        <Grid.Background>
            <ImageBrush Stretch="Fill" ImageSource="/Assets/bg1.png" Opacity="0.4"/>
        </Grid.Background>

        <!-- Main Content -->
        <StackPanel Margin="0,-133,0,49" VerticalAlignment="Bottom" Height="780">
            <StackPanel.RenderTransform>
                <TranslateTransform Y="50"/>
            </StackPanel.RenderTransform>

            <TextBlock toolkit:TurnstileFeatherEffect.FeatheringIndex="0"
                       Text="{Binding Path=LocalizedResources.String34, Source={StaticResource LocalizedStrings}}"
                       FontFamily="Segoe UI Semibold"
                       FontSize="20"
                       Margin="22,0,0,0"
                       HorizontalAlignment="Left"
                       Width="348"
                       Height="30"/>

            <TextBlock toolkit:TurnstileFeatherEffect.FeatheringIndex="1"
                       Text="{Binding Path=LocalizedResources.String35, Source={StaticResource LocalizedStrings}}"
                       FontFamily="Segoe UI Semilight"
                       FontSize="20"
                       Margin="22,0,0,0"
                       HorizontalAlignment="Left"
                       Width="348"
                       Height="26"
                       FontWeight="ExtraLight"/>

            <Image x:Name="AlbumCover"
                   Height="431"
                   Margin="0,10,26,10"
                   Source="Assets/VOL2.jpg"
                   HorizontalAlignment="Right"
                   Width="412"
                   Opacity="0.85"/>

            <TextBlock toolkit:TurnstileFeatherEffect.FeatheringIndex="2"
                       Text="{Binding Path=LocalizedResources.String35, Source={StaticResource LocalizedStrings}}"
                       FontFamily="Segoe WP Semibold"
                       FontSize="30"
                       Margin="31,0,9,0"/>

            <TextBlock toolkit:TurnstileFeatherEffect.FeatheringIndex="3"
                       Text="{Binding Path=LocalizedResources.String36, Source={StaticResource LocalizedStrings}}"
                       FontFamily="Segoe WP SemiLight"
                       FontSize="20"
                       Margin="32,0,0,0"
                       HorizontalAlignment="Left"
                       Width="227"
                       Height="26"/>

            <MediaElement x:Name="AudioPlayer"
              AutoPlay="False"
              Volume="1.0"
              Visibility="Collapsed" />

            <!-- Playback Controls -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="90,20,90,0"
                        Height="65">
                <Button Content="⏪"
                        Click="BackwardButton_Click"
                        Width="80"
                        Height="86"
                        FontSize="36"
                        BorderBrush="{x:Null}"/>

                <Button x:Name="PlayPauseButton"
                        Content="▶"
                        Click="PlayPauseButton_Click"
                        Width="80"
                        Height="80"
                        FontSize="36"
                        Margin="20,0,20,-15"
                        BorderBrush="{x:Null}"/>

                <Button Content="⏩"
                        Click="ForwardButton_Click"
                        Width="80"
                        Height="84"
                        FontSize="36"
                        BorderBrush="{x:Null}"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</phone:PhoneApplicationPage>