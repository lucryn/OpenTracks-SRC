<phone:PhoneApplicationPage
    x:Class="OpenTracksBETA.BrowsePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:shell="clr-namespace:Microsoft.Phone.Shell;assembly=Microsoft.Phone"
    xmlns:phone="clr-namespace:Microsoft.Phone.Controls;assembly=Microsoft.Phone"
    xmlns:toolkit="clr-namespace:Microsoft.Phone.Controls;assembly=Microsoft.Phone.Controls.Toolkit"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <toolkit:TransitionService.NavigationInTransition>
        <toolkit:NavigationInTransition>
            <toolkit:NavigationInTransition.Backward>
                <toolkit:TurnstileFeatherTransition Mode="BackwardIn"/>
            </toolkit:NavigationInTransition.Backward>
            <toolkit:NavigationInTransition.Forward>
                <toolkit:TurnstileFeatherTransition Mode="ForwardIn"/>
            </toolkit:NavigationInTransition.Forward>
        </toolkit:NavigationInTransition>
    </toolkit:TransitionService.NavigationInTransition>

    <toolkit:TransitionService.NavigationOutTransition>
        <toolkit:NavigationOutTransition>
            <toolkit:NavigationOutTransition.Backward>
                <toolkit:TurnstileFeatherTransition Mode="BackwardOut"/>
            </toolkit:NavigationOutTransition.Backward>
            <toolkit:NavigationOutTransition.Forward>
                <toolkit:TurnstileFeatherTransition Mode="ForwardOut"/>
            </toolkit:NavigationOutTransition.Forward>
        </toolkit:NavigationOutTransition>
    </toolkit:TransitionService.NavigationOutTransition>

    <!-- Animation Resources -->
    <phone:PhoneApplicationPage.Resources>
        <QuarticEase x:Key="EaseIn" EasingMode="EaseIn"/>
        <Storyboard x:Name="SlideOutStoryboard">
            <DoubleAnimation
                Storyboard.TargetName="SlideTransform"
                Storyboard.TargetProperty="X"
                From="0" To="100"
                Duration="0:0:0.4"
                EasingFunction="{StaticResource EaseIn}"/>
            <DoubleAnimation
                Storyboard.TargetName="LayoutRoot5"
                Storyboard.TargetProperty="Opacity"
                From="1" To="0"
                Duration="0:0:0.4"
                EasingFunction="{StaticResource EaseIn}"/>
        </Storyboard>
    </phone:PhoneApplicationPage.Resources>
    <!--LayoutRoot is the root grid where all page content is placed-->
    <Grid x:Name="LayoutRoot5" Width="Auto" Height="Auto">
        <Grid.RenderTransform>
            <TranslateTransform x:Name="SlideTransform" />
        </Grid.RenderTransform>

        <!--Panorama control-->
        <phone:Panorama Title="{Binding Path=LocalizedResources.String18, Source={StaticResource LocalizedStrings}}" Foreground="White">
            <phone:Panorama.Background>
                <ImageBrush ImageSource="/Assets/bg1.png" Opacity="0.5" Stretch="UniformToFill"/>
            </phone:Panorama.Background>

            <!--welcome-->
            <phone:PanoramaItem Header="{Binding Path=LocalizedResources.String19, Source={StaticResource LocalizedStrings}}">
                <Grid Margin="0,-22,0,0">
                    <TextBlock HorizontalAlignment="Left" Margin="10,10,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="126" Width="410" FontSize="24">
        	    <Run Text="{Binding Path=LocalizedResources.String20, Source={StaticResource LocalizedStrings}}"/>
                    </TextBlock>
                    <!-- Add your search UI here -->
                    <Button x:Name="aButton"
              Content="{Binding Path=LocalizedResources.String21, Source={StaticResource LocalizedStrings}}"
              FontSize="24"
              Margin="0,141,195,0"
              Click="a1_Click" Height="72" VerticalAlignment="Top" />
                </Grid>
            </phone:PanoramaItem>
            <!--Panorama item one-->
            <phone:PanoramaItem Header="{Binding Path=LocalizedResources.String22, Source={StaticResource LocalizedStrings}}">
                <Grid Margin="0,-22,0,0">
                    <TextBlock HorizontalAlignment="Left" Margin="10,10,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="94" Width="410" FontSize="24">
        	    <Run Text="{Binding Path=LocalizedResources.String23, Source={StaticResource LocalizedStrings}}"/>
                    </TextBlock>
                    <!-- Add your search UI here -->
                    <Button x:Name="bButton"
              Content="{Binding Path=LocalizedResources.String21, Source={StaticResource LocalizedStrings}}"
              FontSize="24"
              Margin="0,109,195,0"
              Click="b1_Click" Height="84" VerticalAlignment="Top" />
                </Grid>
            </phone:PanoramaItem>
            <phone:PanoramaItem Header="{Binding Path=LocalizedResources.String24, Source={StaticResource LocalizedStrings}}">
                <Grid Margin="0,-22,0,0">
                    <TextBlock HorizontalAlignment="Left" Margin="10,0,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="68" Width="410" FontSize="24">
        	    <Run Text="{Binding Path=LocalizedResources.String25, Source={StaticResource LocalizedStrings}}"/>
                    </TextBlock>
                    <!-- Add your search UI here -->
                    <Button x:Name="cButton"
              Content="{Binding Path=LocalizedResources.String21, Source={StaticResource LocalizedStrings}}"
              FontSize="24"
              Margin="0,73,195,0"
              Click="c1_Click" Height="79" VerticalAlignment="Top" />
                </Grid>
            </phone:PanoramaItem>
            <phone:PanoramaItem Header="{Binding Path=LocalizedResources.String26, Source={StaticResource LocalizedStrings}}">
                <Grid Margin="0,-22,0,0">
                    <TextBlock HorizontalAlignment="Left" Margin="10,0,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="64" Width="410" FontSize="24">
        	    <Run Text="{Binding Path=LocalizedResources.String27, Source={StaticResource LocalizedStrings}}"/>
                    </TextBlock>
                    <!-- Add your search UI here -->
                    <Button x:Name="dButton"
              Content="{Binding Path=LocalizedResources.String21, Source={StaticResource LocalizedStrings}}"
              FontSize="24"
              Margin="0,69,207,0"
              Click="d1_Click" Height="85" VerticalAlignment="Top" />
                </Grid>
            </phone:PanoramaItem>
        </phone:Panorama>
        <MediaElement x:Name="AudioPlayer" AutoPlay="False" />
    </Grid>
    <phone:PhoneApplicationPage.ApplicationBar>
        <shell:ApplicationBar IsVisible="True" IsMenuEnabled="True" Mode="Minimized">
            <shell:ApplicationBar.MenuItems>
                <shell:ApplicationBarMenuItem Text="back to home" Click="Home_Click"/>
            </shell:ApplicationBar.MenuItems>
        </shell:ApplicationBar>
    </phone:PhoneApplicationPage.ApplicationBar>
</phone:PhoneApplicationPage>