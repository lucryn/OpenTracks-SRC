<phone:PhoneApplicationPage 
    x:Class="OpenTracksBETA.YTMusic"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:phone="clr-namespace:Microsoft.Phone.Controls;assembly=Microsoft.Phone"
    xmlns:shell="clr-namespace:Microsoft.Phone.Shell;assembly=Microsoft.Phone"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    FontFamily="{StaticResource PhoneFontFamilyNormal}"
    FontSize="{StaticResource PhoneFontSizeNormal}"
    Foreground="{StaticResource PhoneForegroundBrush}"
    SupportedOrientations="Portrait" Orientation="Portrait"
    mc:Ignorable="d" d:DesignHeight="768" d:DesignWidth="480"
    shell:SystemTray.IsVisible="True">

    <phone:PhoneApplicationPage.Resources>
        <Style x:Key="YTButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PhoneAccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="{StaticResource PhoneFontSizeMedium}"/>
            <Setter Property="Height" Value="70"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style x:Key="PlayButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource PhoneAccentBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource PhoneAccentBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Width" Value="50"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>

        <Style x:Key="MiniPlayButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource PhoneAccentBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource PhoneAccentBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </phone:PhoneApplicationPage.Resources>

    <!--LayoutRoot is the root grid where all page content is placed-->
    <Grid x:Name="LayoutRoot">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!--TitlePanel contains the name of the application and page title-->
        <StackPanel x:Name="TitlePanel" Grid.Row="0" Margin="12,17,0,12">
            <TextBlock x:Name="ApplicationTitle" Text="OpenTracksXE" Style="{StaticResource PhoneTextNormalStyle}"/>
            <TextBlock x:Name="PageTitle" Text="YTMusic" Margin="9,-7,0,0" Style="{StaticResource PhoneTextTitle1Style}"/>
        </StackPanel>

        <!--ContentPanel - place additional content here-->
        <Grid x:Name="ContentPanel" Grid.Row="1" Margin="12,0,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!--Search Section-->
            <StackPanel Grid.Row="0" Margin="0,0,0,10">
                <Grid>
                    <TextBox x:Name="SearchTextBox" 
                             Height="100" 
                             FontSize="{StaticResource PhoneFontSizeLarge}"
                             Padding="10"
                             TextChanged="SearchTextBox_TextChanged"
                             Background="Transparent"/>
                    <TextBlock x:Name="SearchHintText" 
                               Text=" Search music..." 
                               FontSize="28"
                               Foreground="{StaticResource PhoneSubtleBrush}"
                               Margin="15,15,0,0"
                               IsHitTestVisible="False"/>
                </Grid>
                <Button x:Name="SearchButton" 
                        Content="Search" 
                        Opacity="0.9"
                        Click="SearchButton_Click"
                        Margin="0,8,0,0" Background="#FFFF1600" BorderBrush="{x:Null}"/>

                <!-- Status Text -->
                <TextBlock x:Name="StatusText" 
                           Text="Ready to search" 
                           FontSize="{StaticResource PhoneFontSizeSmall}"
                           Foreground="{StaticResource PhoneSubtleBrush}"
                           Margin="0,5,0,0"
                           TextAlignment="Center"/>
            </StackPanel>

            <!--Loading Indicator-->
            <StackPanel x:Name="LoadingPanel" 
                       Grid.Row="2" 
                       VerticalAlignment="Center" 
                       Visibility="Collapsed">
                <ProgressBar IsIndeterminate="True" 
                            Width="200"
                            Height="10"
                            Margin="0,0,0,15"/>
                <TextBlock Text="Loading..." 
                           HorizontalAlignment="Center" 
                           FontSize="{StaticResource PhoneFontSizeMediumLarge}"
                           TextWrapping="Wrap"
                           TextAlignment="Center"/>
            </StackPanel>

            <!--Videos List-->
            <ListBox x:Name="VideosListBox" 
                     Grid.Row="2" 
                     Background="Transparent"
                     Visibility="Visible"
                     SelectionChanged="VideosListBox_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,6" Height="100">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!--Thumbnail-->
                            <Border Grid.Column="0" 
                                    Background="{StaticResource PhoneChromeBrush}" 
                                    Width="80" 
                                    Height="80"
                                    Margin="0,0,8,0">
                                <Image Source="{Binding Thumbnail}" 
                                       Stretch="UniformToFill"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                    <Image.Clip>
                                        <RectangleGeometry Rect="0,0,80,80"/>
                                    </Image.Clip>
                                </Image>
                            </Border>

                            <!--Video Info-->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Title}" 
                                           FontSize="{StaticResource PhoneFontSizeMedium}" 
                                           TextWrapping="Wrap" 
                                           TextTrimming="WordEllipsis"
                                           FontWeight="SemiBold"
                                           MaxHeight="45"/>
                                <TextBlock Text="{Binding Channel}" 
                                           FontSize="{StaticResource PhoneFontSizeSmall}" 
                                           Foreground="{StaticResource PhoneAccentBrush}"
                                           TextWrapping="NoWrap" 
                                           TextTrimming="WordEllipsis"/>
                            </StackPanel>

                            <!--Play Button-->
                            <Button Grid.Column="2" 
                                    Content="▶" 
                                    Style="{StaticResource PlayButtonStyle}"
                                    VerticalAlignment="Center"
                                    Click="PlayButton_Click"
                                    Tag="{Binding}"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- Mini Player Bar -->
        <Border Grid.Row="1" 
                Background="{StaticResource PhoneChromeBrush}" 
                Padding="12,8" 
                 Visibility="Collapsed"
                x:Name="MiniPlayerBar" Margin="0,538,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Track Info -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Name="MiniPlayerTitle" 
                               FontSize="{StaticResource PhoneFontSizeSmall}" 
                               TextWrapping="NoWrap" 
                               TextTrimming="WordEllipsis"
                               FontWeight="SemiBold"/>
                    <TextBlock x:Name="MiniPlayerChannel" 
                               FontSize="{StaticResource PhoneFontSizeSmall}" 
                               Foreground="{StaticResource PhoneSubtleBrush}"
                               TextWrapping="NoWrap" 
                               TextTrimming="WordEllipsis"/>
                </StackPanel>

                <!-- Playback Controls -->
                <StackPanel Grid.Column="1" 
                            Orientation="Horizontal" 
                            VerticalAlignment="Center">
                    <Button x:Name="MiniPlayPauseButton" 
                            Content="❚❚" 
                            FontWeight="ExtraBold"
                            Style="{StaticResource MiniPlayButtonStyle}"
                            Margin="8,0,0,0"
                            Click="MiniPlayPauseButton_Click" Height="69" Width="66" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Hidden Video Player for Audio Playback -->
        <MediaElement x:Name="HiddenVideoPlayer"
                     Grid.Row="0" Grid.RowSpan="3"
                     Visibility="Collapsed"
                     AutoPlay="True"/>
        <Grid.Background>
            <ImageBrush ImageSource="/OpenTracksBETA;component/Assets/background.png" Opacity="0.3"/>
        </Grid.Background>
    </Grid>
</phone:PhoneApplicationPage>