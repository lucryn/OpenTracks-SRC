<phone:PhoneApplicationPage
    x:Class="OpenTracksBETA.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:phone="clr-namespace:Microsoft.Phone.Controls;assembly=Microsoft.Phone"
    xmlns:shell="clr-namespace:Microsoft.Phone.Shell;assembly=Microsoft.Phone"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:toolkit="clr-namespace:Microsoft.Phone.Controls;assembly=Microsoft.Phone.Controls.Toolkit"
    toolkit:TransitionService.NavigationInTransition="{StaticResource NavigationInTransition}"
    toolkit:TransitionService.NavigationOutTransition="{StaticResource NavigationOutTransition}"
    mc:Ignorable="d"
    FontFamily="{StaticResource PhoneFontFamilyNormal}"
    FontSize="{StaticResource PhoneFontSizeNormal}"
    Foreground="{StaticResource PhoneForegroundBrush}"
    SupportedOrientations="Portrait"  Orientation="Portrait"
    shell:SystemTray.IsVisible="False">

    <phone:PhoneApplicationPage.Resources>
        <Storyboard x:Name="SlideOutStoryboard">
            <DoubleAnimation
                Storyboard.TargetName="SlideTransform"
                Storyboard.TargetProperty="X"
                From="0" To="480"
                Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <ControlTemplate x:Key="CircularThumbTemplate" TargetType="Thumb">
            <Ellipse Fill="{TemplateBinding Background}"
                 Stroke="{TemplateBinding BorderBrush}"
                 StrokeThickness="{TemplateBinding BorderThickness}"/>
        </ControlTemplate>
        <LinearGradientBrush x:Key="FloatingBarGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E6FFFFFF" Offset="0" />
            <GradientStop Color="#D9FFFFFF" Offset="0.5" />
            <GradientStop Color="#CCF0F0F0" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="PurpleOrangeGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#FF8A2BE2" Offset="0.0"/>
            <GradientStop Color="#FFFFA500" Offset="1.0"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="GlowGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF8A2BE2" Offset="0.0"/>
            <GradientStop Color="#FFFFA500" Offset="1.0"/>
        </LinearGradientBrush>
        <Storyboard x:Name="MarqueeStoryboard" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="TrackTransform"
                     Storyboard.TargetProperty="TranslateX"
                     From="300" To="-600"
                     Duration="0:0:10" />
        </Storyboard>
        <Style x:Key="CircularButtonStyle" TargetType="Button">
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="40"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Metro Slider Style -->
        <Style x:Key="SliderStyle1" TargetType="Slider">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FF005A9E"/>
            <Setter Property="Maximum" Value="100"/>
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Value" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="MouseOver"/>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <DoubleAnimation Duration="0" 
                                                     To="1.5" 
                                                     Storyboard.TargetProperty="(UIElement.Opacity)" 
                                                     Storyboard.TargetName="HorizontalThumb"/>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled"/>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Grid Background="{TemplateBinding Background}">
                                <Grid Margin="0">
                                    <Rectangle x:Name="HorizontalTrack" 
                                       Fill="{TemplateBinding Background}" 
                                       Height="4" 
                                       Margin="0"/>
                                    <Rectangle x:Name="HorizontalTrackHighlight" 
                                       Fill="{TemplateBinding Foreground}" 
                                       Height="4" 
                                       HorizontalAlignment="Left" 
                                       Margin="0"/>
                                    <Thumb x:Name="HorizontalThumb" 
                                   Height="24" 
                                   Width="24" 
                                   DataContext="{TemplateBinding Value}" 
                                   Background="{TemplateBinding Foreground}" 
                                   Template="{StaticResource CircularThumbTemplate}">
                                        <Thumb.RenderTransform>
                                            <TranslateTransform X="0" Y="-10"/>
                                        </Thumb.RenderTransform>
                                    </Thumb>
                                </Grid>
                            </Grid>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Storyboard x:Name="SlideUpStoryboard">
            <DoubleAnimation
            Storyboard.TargetName="NowPlayingTransform"
            Storyboard.TargetProperty="Y"
            To="0"
            Duration="0:0:0.3"/>
        </Storyboard>

        <Storyboard x:Name="SlideDownStoryboard">
            <DoubleAnimation
            Storyboard.TargetName="NowPlayingTransform"
            Storyboard.TargetProperty="Y"
            To="300"
            Duration="0:0:0.3"/>
        </Storyboard>
    </phone:PhoneApplicationPage.Resources>

    <!--LayoutRoot is the root grid where all page content is placed-->
    <Grid x:Name="LayoutRoot" RenderTransformOrigin="0.5,0.5"
      Opacity="1">
        <Grid.Background>
            <ImageBrush ImageSource="/Assets/bg1.png" Stretch="UniformToFill"/>
        </Grid.Background>

        <Grid.RenderTransform>
            <TranslateTransform x:Name="SlideTransform" />
        </Grid.RenderTransform>

        <!--Panorama control-->
        <phone:Panorama x:Name="OpenTracksM" SelectionChanged="OpenTracksM_SelectionChanged">
            <phone:Panorama.Title>
                <Grid HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,20,0,0">
                    <TextBlock Text="{Binding Path=LocalizedResources.String38, Source={StaticResource LocalizedStrings}}"
           FontSize="135"
           FontWeight="ExtraLight"
           Margin="0,0,27,10"
           FontFamily="Segoe WP Light">
                        <TextBlock.Foreground>
                            <!-- Warm contrasting gradient -->
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <!-- Soft white for clarity -->
                                <GradientStop Color="White" Offset="0.0"/>
                                <!-- Vibrant orange accent -->
                                <GradientStop Color="#FFD6D6D6" Offset="0.5"/>
                                <!-- Rich magenta accent -->
                                <GradientStop Color="#FFD6D6D6" Offset="1.0"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>
                </Grid>
            </phone:Panorama.Title>

            <!--welcome-->
            <phone:PanoramaItem Header="welcome" x:Name="HomeItem" Opacity="0.9">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,-25,10,145">
                    <StackPanel Margin="12,0,12,0">
                        <TextBlock Text="Hey! ready for another music joruney?"
                       FontSize="20"
                       FontWeight="ExtraLight"
                       FontFamily="Segoe WP Light"
                       Foreground="#CCFFFFFF"
                       TextWrapping="Wrap"
                       Margin="0,0,0,0"/>

                        <!-- Item 1: 24/7 Live -->
