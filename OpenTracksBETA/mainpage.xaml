                    Margin="0,12,0,0"
                    Padding="24,20"
                    Tag="NavigateToDJ_Tap"
                    Tap="NavigateToDJ_Tap"
                    BorderThickness="0">
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="24/7 Live"
                                   FontSize="48"
                                   FontWeight="ExtraLight"
                                   Foreground="White"
                                   FontFamily="Segoe WP Light"
                                   HorizontalAlignment="Left"/>
                                    <TextBlock Text="Live streaming radio"
                                   FontSize="20"
                                   FontWeight="ExtraLight"
                                   Foreground="#CCFFFFFF"
                                   FontFamily="Segoe WP Light"
                                   Margin="0,4,0,0"
                                   HorizontalAlignment="Left"/>
                                </StackPanel>
                                <TextBlock Text="❚❚"
                               FontSize="28"
                               Foreground="#FF005A9E"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Item 3: Personal Hub -->
                        <Border Background="#FF2A2A2A"
                    Margin="0,12,0,0"
                    Padding="24,20"
                    Tag="NavigateToTracks_Tap"
                    Tap="NavigateToTracks_Tap"
                    BorderThickness="0">
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="Personal Hub"
