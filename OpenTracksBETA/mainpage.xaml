                                   FontWeight="ExtraLight"
                                   Foreground="White"
                                   FontFamily="Segoe WP Light"
                                   HorizontalAlignment="Left"/>
                                    <TextBlock Text="explore more tracks in hub!"
                                   FontSize="20"
                                   FontWeight="ExtraLight"
                                   Foreground="#CCFFFFFF"
                                   FontFamily="Segoe WP Light"
                                   Margin="0,4,0,0"
                                   HorizontalAlignment="Left"/>
                                </StackPanel>
                                <TextBlock Text="☰"
                               FontSize="28"
                               Foreground="#FF005A9E"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Item 2: Marketplace -->
                        <Border Background="#FF333333"
                    Margin="0,12,0,0"
                    Padding="24,20"
                    Tag="NavigateToSettings_Tap"
                    Tap="NavigateToSettings_Tap"
                    BorderThickness="0">
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="Marketplace"
