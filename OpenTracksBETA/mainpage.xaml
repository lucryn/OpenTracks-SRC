                                   FontWeight="ExtraLight"
                                   Foreground="White"
                                   FontFamily="Segoe WP Light"
                                   HorizontalAlignment="Left"/>
                                    <TextBlock Text="Spotify, YTMusic and more..!"
                                   FontSize="20"
                                   FontWeight="ExtraLight"
                                   Foreground="#CCFFFFFF"
                                   FontFamily="Segoe WP Light"
                                   Margin="0,4,0,0"
                                   HorizontalAlignment="Left"/>
                                </StackPanel>
                                <TextBlock Text="▣"
                               FontSize="28"
                               Foreground="#FF005A9E"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Item 4: My Account -->
                        <Border Background="#FF303030"
                    Margin="0,12,0,0"
                    Padding="24,20"
                    Tag="TextBlock_Tap"
                    Tap="TextBlock_Tap"
                    BorderThickness="0">
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="My Account"
                                   FontSize="48"
                                   FontWeight="ExtraLight"
                                   Foreground="White"
                                   FontFamily="Segoe WP Light"
                                   HorizontalAlignment="Left"/>
                                    <TextBlock Text="Profile &amp; preferences"
                                   FontSize="20"
                                   FontWeight="ExtraLight"
                                   Foreground="#CCFFFFFF"
                                   FontFamily="Segoe WP Light"
                                   Margin="0,4,0,0"
                                   HorizontalAlignment="Left"/>
                                </StackPanel>
                                <TextBlock Text="👤"
                               FontSize="28"
                               Foreground="#FF005A9E"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Item 5: App Settings -->
                        <Border Background="#FF383838"
                    Margin="0,12,0,0"
                    Padding="24,20"
                    Tag="TextBlock2_Tap"
                    Tap="TextBlock2_Tap"
                    BorderThickness="0">
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="App Settings"
                                   FontSize="48"
                                   FontWeight="ExtraLight"
                                   Foreground="White"
                                   FontFamily="Segoe WP Light"
                                   HorizontalAlignment="Left"/>
                                    <TextBlock Text="Customize your experience"
                                   FontSize="20"
                                   FontWeight="ExtraLight"
                                   Foreground="#CCFFFFFF"
                                   FontFamily="Segoe WP Light"
                                   Margin="0,4,0,0"
                                   HorizontalAlignment="Left"/>
                                </StackPanel>
                                <TextBlock Text="⚙"
                               FontSize="28"
                               Foreground="#FF005A9E"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Item 6: About -->
                        <Border Background="#FF3C3C3C"
                    Margin="0,12,0,0"
                    Padding="24,20"
                    Tag="TextBlock1_Tap"
                    Tap="TextBlock1_Tap"
                    BorderThickness="0">
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="About"
                                   FontSize="48"
                                   FontWeight="ExtraLight"
                                   Foreground="White"
                                   FontFamily="Segoe WP Light"
                                   HorizontalAlignment="Left"/>
                                    <TextBlock Text="App info &amp; credits"
                                   FontSize="20"
                                   FontWeight="ExtraLight"
                                   Foreground="#CCFFFFFF"
                                   FontFamily="Segoe WP Light"
                                   Margin="0,4,0,0"
                                   HorizontalAlignment="Left"/>
                                </StackPanel>
                                <TextBlock Text="ⓘ"
                               FontSize="28"
                               Foreground="#FF005A9E"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Login Status Panel -->
                        <Border Background="#FF444444"
                    Margin="0,24,0,12"
                    Padding="20,16"
                    x:Name="LoginStatusPanel"
                    Visibility="Collapsed"
                    BorderThickness="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Ellipse Width="48"
                             Height="48"
                             Fill="#FF005A9E"
                             VerticalAlignment="Center">
                                    <Ellipse.RenderTransform>
                                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                                    </Ellipse.RenderTransform>
                                </Ellipse>

                                <StackPanel Grid.Column="1"
                                Margin="16,0,0,0"
                                VerticalAlignment="Center">
                                    <TextBlock Text="Signed in as"
                                   FontSize="18"
                                   FontWeight="ExtraLight"
                                   Foreground="#FFCCCCCC"
                                   FontFamily="Segoe WP Light"/>
                                    <TextBlock x:Name="LoggedInUserText"
                                   FontSize="22"
                                   FontWeight="ExtraLight"
                                   Foreground="White"
                                   FontFamily="Segoe WP Light"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </phone:PanoramaItem>

            <!-- Panorama item one -->
            <phone:PanoramaItem Header="{Binding Path=LocalizedResources.String45, Source={StaticResource LocalizedStrings}}" x:Name="NewTracksItem">
                <Grid x:Name="NewTracksGrid" Margin="0">
                    <Grid x:Name="SignedInContent1" Visibility="Visible"
              VerticalAlignment="Stretch"
              HorizontalAlignment="Stretch">
                        <TextBlock Text="These tracks will be avaliable in limited-time!"
                                       FontSize="20"
                                       FontWeight="ExtraLight"
                                       FontFamily="Segoe WP Light"
                                       Foreground="#CCFFFFFF"
                                       TextWrapping="Wrap"
                                       Margin="15,-40,0,471"/>
                        <ListBox x:Name="NewTracks"
                     ItemsSource="{Binding NewTracks}"
                     SelectionChanged="NewTracks_SelectionChanged"
                     VerticalAlignment="Stretch"
                     HorizontalAlignment="Stretch"
                     Margin="16,2,-4,147">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,10,0,10"
                                    Hold="Track_Hold">
                                        <TextBlock Text="{Binding Title}"
                                       FontSize="36"
                                       FontWeight="ExtraLight"
                                       FontFamily="Segoe WP Light"
                                       Foreground="White"
                                       TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding Artist}"
                                       FontSize="28"
                                       FontWeight="ExtraLight"
                                       FontFamily="Segoe WP Light"
                                       Foreground="#CCFFFFFF"
