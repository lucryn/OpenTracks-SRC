                                       Margin="0,5,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>

                    <StackPanel x:Name="GuestMessage1"
                    Visibility="Collapsed"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="20">
                        <TextBlock Text="Please sign in to use this function"
                       FontSize="24"
                       TextAlignment="Center"
                       Margin="0,0,0,10"/>
                        <Button Content="Sign In"
                    Click="GoToLogin_Click"
                    Margin="10"/>
                    </StackPanel>
                </Grid>
            </phone:PanoramaItem>

            <!-- Panorama item one -->
            <phone:PanoramaItem Header="new tracks" x:Name="TopHitsItem">
                <Grid x:Name="TracksGrid" Margin="0">
                    <Grid x:Name="SignedInContent2" Visibility="Visible" Margin="0,0,0,0">
                        <ListBox x:Name="Tracks"
                     ItemsSource="{Binding Tracks}"
                     SelectionChanged="Tracks_SelectionChanged"
                     VerticalAlignment="Stretch"
                     HorizontalAlignment="Stretch"
                     Margin="16,-28,-4,149">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,10,0,10"
                                    Hold="Track_Hold">
                                        <TextBlock Text="{Binding Title}"
                                       FontSize="36"
                                       FontWeight="ExtraLight"
                                       FontFamily="Segoe WP Light"
                                       Foreground="White"
                                       TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding Artist}"
                                       FontSize="28"
                                       FontWeight="ExtraLight"
                                       FontFamily="Segoe WP Light"
                                       Foreground="#CCFFFFFF"
                                       TextWrapping="Wrap"
                                       Margin="0,5,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>

                    <StackPanel x:Name="GuestMessage2"
                    Visibility="Collapsed"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="20">
                        <TextBlock Text="Please sign in to use this function"
                       FontSize="24"
                       TextAlignment="Center"
                       Margin="0,0,0,10"/>
                        <Button Content="Sign In"
                    Click="GoToLogin_Click"
                    Margin="10"/>
                    </StackPanel>
                </Grid>
            </phone:PanoramaItem>

            <!-- Panorama item two -->
            <phone:PanoramaItem Header="{Binding Path=LocalizedResources.String47, Source={StaticResource LocalizedStrings}}" x:Name="TracksItem">
                <Grid x:Name="AllTracksGrid" Margin="-12,-49,0,0">
                    <!-- Search Box at the top -->
                    <StackPanel x:Name="og">
                        <TextBox x:Name="SearchBox"
                     Height="78"
                     Margin="12,12,12,10"
                     TextChanged="SearchBox_TextChanged"
                     VerticalAlignment="Top"/>

                        <!-- Search Results List -->
                        <ListBox x:Name="SearchResults"
                     ItemsSource="{Binding FilteredTracks}"
                     SelectionChanged="TracksList_SelectionChanged" 
                     Margin="12,0,0,0"
                     VerticalAlignment="Stretch"
                     HorizontalAlignment="Stretch"
                     Visibility="Collapsed">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="12,10,0,10">
                                        <TextBlock Text="{Binding Title}"
                                       FontSize="36"
                                       FontWeight="ExtraLight"
                                       FontFamily="Segoe WP Light"
                                       Foreground="White"
                                       TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding Artist}"
                                       FontSize="28"
                                       FontWeight="ExtraLight"
                                       FontFamily="Segoe WP Light"
                                       Foreground="#CCFFFFFF"
                                       TextWrapping="Wrap"
                                       Margin="0,5,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Regular AllTracks List (shown when not searching) -->
                        <Grid x:Name="SignedInContent3" Visibility="Visible" Margin="33,0,31,0" Height="342">
                            <ListBox x:Name="AllTracks"
                         ItemsSource="{Binding AllTracks}"
                         SelectionChanged="AllTracks_SelectionChanged"
                         VerticalAlignment="Stretch"
                         HorizontalAlignment="Stretch" Margin="0,0,0,43"
                                     >
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,10,0,10"
                                        Hold="Track_Hold">
                                            <TextBlock Text="{Binding Title}"
                                           FontSize="36"
                                           FontWeight="ExtraLight"
                                           FontFamily="Segoe WP Light"
                                           Foreground="White"
                                           TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Artist}"
                                           FontSize="28"
                                           FontWeight="ExtraLight"
                                           FontFamily="Segoe WP Light"
                                           Foreground="#CCFFFFFF"
                                           TextWrapping="Wrap"
                                           Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </StackPanel>

                    <!-- Message shown only when NOT signed in -->
                    <StackPanel x:Name="GuestMessage3"
                    Visibility="Collapsed"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="20">
                        <TextBlock Text="Please sign in to use this function"
                       FontSize="24"
                       TextAlignment="Center"
                       Margin="0,0,0,10"/>
                        <Button Content="Sign In"
                    Click="GoToLogin_Click"
                    Margin="10"/>
                    </StackPanel>
                </Grid>
            </phone:PanoramaItem>

           
            <!--Panorama item one-->
            <phone:PanoramaItem Header="{Binding Path=LocalizedResources.String52, Source={StaticResource LocalizedStrings}}">
                <TextBlock HorizontalAlignment="Left" Margin="16,-22,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="487" Width="400" FontSize="24">
                	<Run Text="{Binding Path=LocalizedResources.String53, Source={StaticResource LocalizedStrings}}"/><Run Text=" : Stable 1.1"/>
                	<LineBreak/>
                	<Run Text="{Binding Path=LocalizedResources.String54, Source={StaticResource LocalizedStrings}}"/><Run Text=": AMOLED Update 1"/>
                	<LineBreak/>
                	<Run Text="{Binding Path=LocalizedResources.String55, Source={StaticResource LocalizedStrings}}"/>
                	<LineBreak/>
                	<Run Text="{Binding Path=LocalizedResources.String56, Source={StaticResource LocalizedStrings}}"/>
                	<LineBreak/>
                	<LineBreak/>
                	<Run Text="{Binding Path=LocalizedResources.String57, Source={StaticResource LocalizedStrings}}"/>
                	<LineBreak/>
                	<Run Text="ChockingNetDude"/>
                	<LineBreak/>
                	<LineBreak/>
                	<Run Text="{Binding Path=LocalizedResources.String58, Source={StaticResource LocalizedStrings}}"/>
                	<LineBreak/>
                	<Run Text="droidjacks4@gmail.com"/>
                	<LineBreak/>
                	<Run Text="Telegram@chockingnetdude"/>
                </TextBlock>
            </phone:PanoramaItem>
        </phone:Panorama>

        <!-- Mini Player at Bottom -->

        <!-- Mini Player at Bottom - Updated to match chillin.xaml -->
        <StackPanel VerticalAlignment="Bottom"
            HorizontalAlignment="Stretch"
            Background="#FF272727"
            Height="140"
            Margin="0">

            <!-- 🔊 Top Row: Track Title & Play Button -->
            <StackPanel Orientation="Horizontal"
                Height="80"
                Margin="0">
                <TextBlock x:Name="CurrentTrackName"
           FontSize="40"
           FontWeight="Light"
           Foreground="White"
           Text=" It's empty here :("
           TextWrapping="NoWrap"
           RenderTransformOrigin="0.5,0.5"
           VerticalAlignment="Center"
           HorizontalAlignment="Left"
           Margin="10,16,0,4"
           Width="372"
           Height="60"
           Tap="MiniControlBarWrapper_Tap">
                    <TextBlock.RenderTransform>
                        <!-- Make sure this is CompositeTransform, not TranslateTransform -->
                        <CompositeTransform x:Name="TrackTransform" />
                    </TextBlock.RenderTransform>
                </TextBlock>

                <Button x:Name="MiniPlayPauseButton"
                Width="66"
                Height="70"
                Content="▶"
                FontSize="32"
                FontWeight="Bold"
                Background="{x:Null}"
                Foreground="White"
                BorderBrush="White"
                BorderThickness="2"
                Style="{StaticResource CircularButtonStyle}"
                Click="PlayPauseButton_Click"
                VerticalAlignment="Center"
                HorizontalAlignment="Right"
                Margin="10,10,10,0" />
            </StackPanel>

            <!-- 📊 Slider Row: Time Labels + Seek Bar -->
            <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center"
                Height="40"
                Margin="10,0,10,10">

                <TextBlock x:Name="StartTimeLabel"
                   Text="0:00"
                   FontSize="18"
                   Foreground="White"
                   VerticalAlignment="Center"
                   Margin="0,10,10,0"
                   Height="30" />

                <Slider x:Name="ProgressSlider"
                Minimum="0"
                Maximum="100"
                Value="0"
                Width="346"
                Height="118"
                Background="#FF5F5F5F"
                Foreground="White"
                BorderBrush="{x:Null}"
                ValueChanged="ProgressSlider_ValueChanged"
                VerticalAlignment="Center"
                Margin="0,-23,0,-55" />

                <TextBlock x:Name="EndTimeLabel"
                   Text="0:00"
                   FontSize="18"
                   Foreground="White"
                   VerticalAlignment="Center"
                   Margin="10,0,0,0" />
            </StackPanel>
        </StackPanel>

        <!-- Full Now Playing Panel -->
        <!-- Metro Style Full Screen Player -->
        <Grid x:Name="NowPlayingPanel"
      VerticalAlignment="Stretch"
      HorizontalAlignment="Stretch"
      RenderTransformOrigin="0.5,0.5" 
      Visibility="Collapsed"
      Background="#FF1A1A1A">

            <Grid.RenderTransform>
                <TransformGroup>
                    <TranslateTransform x:Name="NowPlayingTransform" Y="800"/>
                </TransformGroup>
            </Grid.RenderTransform>

            <!-- Close Button (Top Right) -->
            <Button x:Name="CloseNowPlayingButton"
            Click="MinimizeNowPlaying_Click"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Width="72"
            Height="72"
            BorderThickness="0"
            Background="Transparent"
            Margin="0,40,20,0">
                <Grid>
                    <Ellipse Width="44"
                     Height="44"
                     Fill="#33FFFFFF"/>
                    <TextBlock Text="✕"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
                </Grid>
            </Button>

            <!-- Main Content -->
            <Grid VerticalAlignment="Center"
          HorizontalAlignment="Center"
          Width="440"
          Margin="0,80,0,20">

                <!-- Track Info with Metro typography -->
                <StackPanel Margin="0,50,0,200"
                    HorizontalAlignment="Center">
                    <TextBlock x:Name="NowPlayingTitle"
                       Text="Now Playing"
                       FontSize="48"
                       FontWeight="Light"
                       Foreground="White"
                       FontFamily="Segoe WP Light"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       Margin="0,0,0,12"
                       MaxWidth="400"/>

                    <TextBlock x:Name="NowPlayingArtist"
                       Text="Artist Name"
                       FontSize="28"
                       FontWeight="Light"
                       Foreground="#FFCCCCCC"
                       FontFamily="Segoe WP Light"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       Margin="0,0,0,8"/>

                    <TextBlock x:Name="NowPlayingSource"
                       Text="From: Browse"
                       FontSize="20"
                       FontWeight="Light"
                       Foreground="#FF888888"
                       FontFamily="Segoe WP Light"
                       TextAlignment="Center"/>
                </StackPanel>

                <!-- Progress Bar -->
                <Grid Margin="0,0,0,40"
              VerticalAlignment="Bottom">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Time Labels -->
                    <Grid Grid.Row="0"
                  Margin="0,0,0,8">
                        <TextBlock x:Name="StartTimeLabel1"
                           Text="0:00"
                           FontSize="18"
                           FontWeight="Light"
                           Foreground="#FFCCCCCC"
                           FontFamily="Segoe WP Light"
                           HorizontalAlignment="Left"/>

                        <TextBlock x:Name="EndTimeLabel1"
                           Text="0:00"
                           FontSize="18"
                           FontWeight="Light"
                           Foreground="#FFCCCCCC"
                           FontFamily="Segoe WP Light"
                           HorizontalAlignment="Right"/>
                    </Grid>

                    <!-- Metro-style Progress Bar -->
                    <Grid Grid.Row="1"
                  Height="4"
                  Background="#FF444444">
                        <Rectangle x:Name="ProgressFill"
                           Fill="#FF005A9E"
                           HorizontalAlignment="Left"
                           Width="0"
                           Height="4"/>
                    </Grid>

                    <!-- Hidden Slider for interaction -->
                    <Slider x:Name="FullScreenProgressSlider"
                    Grid.Row="1"
                    Minimum="0"
                    Maximum="100"
                    Value="0"
                    Height="40"
                    Background="Transparent"
                    Foreground="Transparent"
                    BorderBrush="Transparent"
                    Style="{StaticResource SliderStyle1}"
                    ValueChanged="FullScreenProgressSlider_ValueChanged"
                    Opacity="0"/>
                </Grid>

                <!-- Metro-style Playback Controls -->
                <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,60"
                    VerticalAlignment="Bottom">
                    <!-- Previous Button -->
                    <Button x:Name="PrevButton"
                    Width="72"
                    Height="72"
                    Background="Transparent"
                    Click="BackwardButton_Click"
                    Margin="0,0,24,0">
                        <Grid>
                            <Ellipse Width="56"
                             Height="56"
                             Fill="#33FFFFFF"/>
                            <TextBlock Text="⏮"
                               FontSize="24"
                               FontWeight="Light"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                    <!-- Play/Pause Button (Prominent Metro Circle) -->
                    <Button x:Name="FullPlayPauseButton"
                    Width="88"
                    Height="88"
                    Click="PlayPauseButton_Click"
                    Margin="0,0,24,0">
                        <Grid>
                            <Ellipse Fill="#FF005A9E"/>
                            <TextBlock x:Name="PlayPauseText"
                               Text="▶"
                               FontSize="32"
                               FontWeight="Light"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                    <!-- Next Button -->
                    <Button x:Name="NextButton"
                    Width="72"
                    Height="72"
                    Background="Transparent"
                    Click="ForwardButton_Click">
                        <Grid>
                            <Ellipse Width="56"
                             Height="56"
                             Fill="#33FFFFFF"/>
                            <TextBlock Text="⏭"
                               FontSize="24"
                               FontWeight="Light"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                        </Grid>
                    </Button>
                </StackPanel>

                <!-- Volume Control (Metro Style) -->
                <StackPanel Margin="0,40,0,0"
                    VerticalAlignment="Bottom">
                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="VOLUME"
                           FontSize="16"
                           FontWeight="Light"
                           Foreground="#FF888888"
                           FontFamily="Segoe WP Light"
                           HorizontalAlignment="Left"/>

                        <TextBlock x:Name="VolumeLabel"
                           Text="100%"
                           FontSize="16"
                           FontWeight="Light"
                           Foreground="#FF888888"
                           FontFamily="Segoe WP Light"
                           HorizontalAlignment="Right"/>
                    </Grid>

                    <!-- Metro-style Volume Slider -->
                    <Grid Height="4"
                  Background="#FF444444"
                  Margin="0,0,0,8">
                        <Rectangle x:Name="VolumeFill"
                           Fill="#FF005A9E"
                           HorizontalAlignment="Left"
                           Width="100"
                           Height="4"/>
                    </Grid>

                    <Slider x:Name="VolumeSlider"
                    Minimum="0"
                    Maximum="100"
                    Value="100"
                    Height="40"
                    Background="Transparent"
                    Foreground="Transparent"
                    BorderBrush="Transparent"
                    ValueChanged="VolumeSlider_ValueChanged"
                    Opacity="0"/>
                </StackPanel>
            </Grid>
        </Grid>
        <MediaElement x:Name="AudioPlayer" 
              AutoPlay="False" 
              Visibility="Collapsed"
              MediaOpened="AudioPlayer_MediaOpened"
              MediaEnded="AudioPlayer_MediaEnded"
              MediaFailed="AudioPlayer_MediaFailed" />
    </Grid>
</phone:PhoneApplicationPage>