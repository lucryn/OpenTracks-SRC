<phone:PhoneApplicationPage
    x:Class="OpenTracksBETA.SplashPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:phone="clr-namespace:Microsoft.Phone.Controls;assembly=Microsoft.Phone"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" Orientation="Portrait">

    <phone:PhoneApplicationPage.Resources>
        <QuarticEase x:Key="EaseOut" EasingMode="EaseOut"/>

        <!-- Splash entrance -->
        <Storyboard x:Name="SplashInStoryboard">
            <DoubleAnimation Storyboard.TargetName="SplashTransform"
                     Storyboard.TargetProperty="TranslateY"
                     From="100" To="0"
                     Duration="0:0:0.6"
                     EasingFunction="{StaticResource EaseOut}"/>
            <DoubleAnimation Storyboard.TargetName="SplashImage"
                     Storyboard.TargetProperty="Opacity"
                     From="0" To="1"
                     Duration="0:0:0.6"
                     EasingFunction="{StaticResource EaseOut}"/>
        </Storyboard>

        <!-- Splash exit -->
        <Storyboard x:Name="SplashOutStoryboard">
            <DoubleAnimation Storyboard.TargetName="SplashTransform"
                     Storyboard.TargetProperty="TranslateX"
                     From="0" To="480"
                     Duration="0:0:0.4"
                     EasingFunction="{StaticResource EaseOut}"/>
            <DoubleAnimation Storyboard.TargetName="SplashImage"
                     Storyboard.TargetProperty="Opacity"
                     From="1" To="0"
                     Duration="0:0:0.4"
                     EasingFunction="{StaticResource EaseOut}"/>
        </Storyboard>
    </phone:PhoneApplicationPage.Resources>


    <Grid Background="Black">
        <StackPanel Margin="-102,-10,-92,-156">
            <Image x:Name="SplashImage"
       Source="/Assets/OpenTracks_3.png"
       Height="859.79"
       Opacity="0"
       RenderTransformOrigin="0.5,0.5"
       Margin="-90.237,0,-104.561,0">
                <Image.RenderTransform>
                    <CompositeTransform x:Name="SplashTransform"
                        TranslateY="100"
                        TranslateX="0"/>
                </Image.RenderTransform>
            </Image>
        </StackPanel>
    </Grid>
</phone:PhoneApplicationPage>