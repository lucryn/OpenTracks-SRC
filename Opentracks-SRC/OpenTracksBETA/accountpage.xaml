<phone:PhoneApplicationPage
    x:Class="OpenTracksBETA.AccountPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:phone="clr-namespace:Microsoft.Phone.Controls;assembly=Microsoft.Phone"
    FontFamily="Segoe UI"
    Background="#F0F4F8" Orientation="Portrait">

    <phone:PhoneApplicationPage.Resources>
        <QuarticEase x:Key="EaseOut" EasingMode="EaseOut"/>
        <QuarticEase x:Key="EaseIn" EasingMode="EaseIn"/>

        <!-- Slide In -->
        <Storyboard x:Name="SlideInStoryboard">
            <DoubleAnimation
                Storyboard.TargetName="SlideTransform"
                Storyboard.TargetProperty="X"
                From="-100" To="0"
                Duration="0:0:0.5"
                EasingFunction="{StaticResource EaseOut}"/>
            <DoubleAnimation
                Storyboard.TargetName="MainContent"
                Storyboard.TargetProperty="Opacity"
                From="0" To="1"
                Duration="0:0:0.5"
                EasingFunction="{StaticResource EaseOut}"/>
        </Storyboard>

        <!-- Slide Out -->
        <Storyboard x:Name="SlideOutStoryboard">
            <DoubleAnimation
                Storyboard.TargetName="SlideTransform"
                Storyboard.TargetProperty="X"
                From="0" To="100"
                Duration="0:0:0.4"
                EasingFunction="{StaticResource EaseIn}"/>
            <DoubleAnimation
                Storyboard.TargetName="MainContent"
                Storyboard.TargetProperty="Opacity"
                From="1" To="0"
                Duration="0:0:0.4"
                EasingFunction="{StaticResource EaseIn}"/>
        </Storyboard>
    </phone:PhoneApplicationPage.Resources>

    <Grid x:Name="MainContent"
          
          RenderTransformOrigin="0.5,0.5">
        <Grid.RenderTransform>
            <TranslateTransform x:Name="SlideTransform" X="-100"/>
        </Grid.RenderTransform>

        <StackPanel Margin="24">
            <!-- Title -->
            <TextBlock Text="{Binding Path=LocalizedResources.String28, Source={StaticResource LocalizedStrings}}"
                       FontSize="36"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="0,0,0,24" />

            <!-- Info Cards -->
            <Border Background="White" CornerRadius="12" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{Binding Path=LocalizedResources.String29, Source={StaticResource LocalizedStrings}}" FontWeight="SemiBold" FontSize="18" Foreground="#34495E"/>
                    <TextBlock x:Name="EmailText" FontSize="20" Foreground="#2C3E50" />
                </StackPanel>
            </Border>

            <Border Background="White" CornerRadius="12" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{Binding Path=LocalizedResources.String30, Source={StaticResource LocalizedStrings}}" FontWeight="SemiBold" FontSize="18" Foreground="#34495E"/>
                    <TextBlock x:Name="UserIdText" FontSize="20" Foreground="#2C3E50" />
                </StackPanel>
            </Border>

            <Border Background="White" CornerRadius="12" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{Binding Path=LocalizedResources.String31, Source={StaticResource LocalizedStrings}}" FontWeight="SemiBold" FontSize="18" Foreground="#34495E"/>
                    <TextBlock x:Name="DeviceNameText" FontSize="20" Foreground="#2C3E50" />
                </StackPanel>
            </Border>

            <Border Background="White" CornerRadius="12" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{Binding Path=LocalizedResources.String32, Source={StaticResource LocalizedStrings}}" FontWeight="SemiBold" FontSize="18" Foreground="#34495E"/>
                    <TextBlock x:Name="OSVersionText" FontSize="20" Foreground="#2C3E50" />
                </StackPanel>
            </Border>

            <Border Background="White" CornerRadius="12" Padding="16" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="{Binding Path=LocalizedResources.String33, Source={StaticResource LocalizedStrings}}" FontWeight="SemiBold" FontSize="18" Foreground="#34495E"/>
                    <TextBlock x:Name="ManufacturerText" FontSize="20" Foreground="#2C3E50" />
                </StackPanel>
            </Border>

            <!-- Action Button -->
            <Button Content="Logout"
                    Click="Logout_Click"
                    Background="#3498DB"
                    Foreground="White"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Padding="12"
                    FontSize="20" />
        </StackPanel>
    </Grid>
</phone:PhoneApplicationPage>